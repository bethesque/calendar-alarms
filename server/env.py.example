SCOPE = "https://www.googleapis.com/auth/calendar.readonly"

SERVER_ADDRESS = "https://some.dns.that.resolves.to.calendar.ip"

login_hint = "emailYouMostLikelyWant@gmail.com"

filter = [
    ("calendarNameInGoogle", "NameToRenderOnDevice"),
]

DATA_DIRECTORY = "/home/beth/calendar-alarms"
CACHE_DIRECTORY = "./cache"
RESOURCES_DIRECTORY = "./resources"

# Must match the configuration for bind_to_address in /etc/mpd.conf
MPD_HOST = "/tmp/mpd.socket"

# Set to 0 when using a socket
MPD_PORT = 0

INITIAL_VOLUME = 60

ANNOUNCEMENT_SOUND_EFFECT_PROBABILITY = 1/3

DEFAULT_GOOGLE_TRANSLATE_TLD = "com.au"

GOOGLE_TRANSLATE_LANG = "en"
