[Unit]
Description=Sendspin ARMv6 Audio Player
After=network-online.target time-sync.target
Wants=network-online.target time-sync.target

StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
# Logs at journalctl SYSLOG_IDENTIFIER=sendspin-armv6
ExecStart=/usr/local/bin/sendspin-armv6
Restart=on-failure
RestartSec=10
Nice=-10

LimitRTPRIO=10
LimitMEMLOCK=infinity

[Install]
WantedBy=default.target
