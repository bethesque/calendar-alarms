#!/usr/bin/env bash
# Fetches and saves the client ID from the snapserver
set -euo pipefail

HOSTNAME="$(hostname)"
SNAPCLIENT_HOST_ID="{{ ca_snapclient_host_id }}"
SNAPSERVER="{{ ca_snapserver_rpc_url }}"
OUTFILE="${XDG_RUNTIME_DIR}/calendar-alarms-snapclient/client_id.txt"

mkdir -p "$(dirname "$OUTFILE")"

for i in {1..15}; do
  response=$(curl -s -X POST "$SNAPSERVER" \
    -H "Content-Type: application/json" \
    -d '{"id":1,"jsonrpc":"2.0","method":"Server.GetStatus"}')

  # Match client by host/name/id field (Snapcast varies by version)
  client_id=$(echo "$response" | jq -r --arg hostname "$HOSTNAME" --arg ca_snapclient_host_id "$SNAPCLIENT_HOST_ID" '
    .result.server.groups[]?.clients[]
    | select(
        .connected == true
        and .host.name == $hostname
        and (
              .id == $ca_snapclient_host_id
              or select(.id | startswith($ca_snapclient_host_id + "#"))
            )
      )
    | .id
  ' | head -n 1)

  if [[ -n "${client_id:-}" && "$client_id" != "null" ]]; then
    echo "$client_id" > "$OUTFILE"
    exit 0
  fi

  sleep 1
done

exit 1
