[stream]
port = {{ ca_snapserver_stream_port }}
source = pipe://{{ mpd_fifo_path }}?name=mpd&codec=pcm&sampleformat={{ audio_format }}
# source = file:///tmp/bethtest.wav?name=bethtest

[http]
enabled = true
bind_to_address = 0.0.0.0
port = {{ ca_snapserver_http_port }}
doc_root = {{ snapweb_doc_root }}

[tcp]
enabled = true
bind_to_address = 0.0.0.0
port = {{ ca_snapserver_tcp_port }}
