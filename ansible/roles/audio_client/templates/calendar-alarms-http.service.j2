[Unit]
Description=Calendar Alarms HTTP
After=network.target

[Service]
WorkingDirectory={{ http_index_file | dirname }}
ExecStart={{ ansible_python_interpreter }} {{ http_index_file }} --snapserver_rpc_url {{ snapserver_rpc_url }} --client_id_file {{ snapclient_client_id_file }}
SyslogIdentifier=calendar-alarms-http
Restart=always

[Install]
WantedBy=default.target
